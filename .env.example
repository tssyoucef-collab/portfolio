# ──────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS whitelist). Set to your Render.com URL once deployed.
FRONTEND_URL=https://your-app.onrender.com

# Session secret (generate a strong random string: openssl rand -hex 32)
SESSION_SECRET=replace_with_a_strong_random_secret

# ──────────────────────────────────────
# Firebase Admin SDK
# ──────────────────────────────────────
# Path to your Firebase service account JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ──────────────────────────────────────
# Firebase Client SDK (embedded in frontend)
# ──────────────────────────────────────
# These are your Firebase project's web app config values.
# They are public keys (safe to embed in client-side code).
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# ──────────────────────────────────────
# Session Cookie
# ──────────────────────────────────────
# Max session age in milliseconds (default: 5 days)
SESSION_MAX_AGE=432000000
