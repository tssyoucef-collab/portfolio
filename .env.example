# ──────────────────────────────────────
# Server Configuration
# ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS whitelist). Set to your Render.com URL once deployed.
FRONTEND_URL=https://youcef-portfolio.onrender.com

# Session secret (generate a strong random string: openssl rand -hex 32)
SESSION_SECRET=jK8xP2vR9qL5mN3wY6aZ

# ──────────────────────────────────────
# Firebase Admin SDK
# ──────────────────────────────────────
# Path to your Firebase service account JSON key file
FIREBASE_SERVICE_ACCOUNT_PATH=/etc/secrets/firebase-service-account.json

# ──────────────────────────────────────
# Firebase Client SDK (embedded in frontend)
# ──────────────────────────────────────
# These are your Firebase project's web app config values.
# They are public keys (safe to embed in client-side code).
FIREBASE_API_KEY=AIzaSyA_jJ4Di1p6fUNGiVha3rBI8MkvjLJkGXs
FIREBASE_AUTH_DOMAIN=youcef-portfolio.firebaseapp.com
FIREBASE_PROJECT_ID=youcef-portfolio
FIREBASE_STORAGE_BUCKET=youcef-portfolio.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=739794960924
FIREBASE_APP_ID=1:739794960924:web:218aceb2879556fea795d9

# ──────────────────────────────────────
# Session Cookie
# ──────────────────────────────────────
# Max session age in milliseconds (default: 5 days)
SESSION_MAX_AGE=432000000
